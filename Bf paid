    end)

    -- HIDE/SHOW
    hideBtn.Activated:Connect(function()
        mainFrame.Visible = false
        floatingCircle.Visible = true
    end)

    floatingCircle.Activated:Connect(function()
        mainFrame.Visible = true
        floatingCircle.Visible = false
    end)

    -- DRAG
    local dragStart, frameStart, isDragging
    mainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            dragStart = input.Position
            frameStart = mainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)

    local circleDragStart, circleStartPos, isCircleDragging
    floatingCircle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isCircleDragging = true
            circleDragStart = input.Position
            circleStartPos = floatingCircle.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isCircleDragging and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - circleDragStart
            floatingCircle.Position = UDim2.new(circleStartPos.X.Scale, circleStartPos.X.Offset + delta.X, circleStartPos.Y.Scale, circleStartPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isCircleDragging = false
        end
    end)

    -- CLEANUP
    Players.PlayerRemoving:Connect(function(player)
        if espLabels[player] then
            espLabels[player]:Destroy()
            espLabels[player] = nil
