    -- GET ENEMIES
    local function getAllEnemies()
        local enemies = {}
        for _, child in pairs(workspace:GetDescendants()) do
            if child:FindFirstChild("Humanoid") and child.Humanoid.Health > 0 and child:FindFirstChild("HumanoidRootPart") then
                if child ~= LocalPlayer.Character and not child:IsDescendantOf(LocalPlayer.Character) then
                    table.insert(enemies, child)
                end
            end
        end
        return enemies
    end

    -- 1 HIT KILL
    local function oneHitKill()
        if not oneHitKillEnabled then return end
        local enemies = getAllEnemies()
        for _, enemy in pairs(enemies) do
            if enemy and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                enemy.Humanoid.Health = 0
            end
        end
    end

    -- AUTO FARM
    local function autoFarm()
        if not autoFarmEnabled then return end
        local enemies = getAllEnemies()
        if #enemies == 0 then return end
        
        local nearest = nil
        local shortestDist = math.huge
        for _, enemy in pairs(enemies) do
            local root = enemy:FindFirstChild("HumanoidRootPart")
            if root and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (root.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if dist < shortestDist then
                    shortestDist = dist
                    nearest = enemy
                end
            end
        end
        
        if nearest and nearest.HumanoidRootPart then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            if hrp then
                hrp.CFrame = nearest.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)
            end
            wait(0.05)
            pcall(function()
                VirtualUser:Button1Down(Vector2.new(0,0))
                wait(0.02)
                VirtualUser:Button1Up(Vector2.new(0,0))
            end)
        end
    end

    -- AUTO COLLECT
    local function autoCollect()
        if not autoCollectEnabled then return end
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") and v:FindFirstChild("ClickDetector") then
                local name = v.Name:lower()
                if name:find("fruit") or name:find("chest") or name:find("drop") or name:find("beli") then
                    local cd = v:FindFirstChild("ClickDetector")
                    if cd and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        local dist = (v:GetPivot().Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                        if dist < 80 then
                            fireclickdetector(cd)
                            wait(0.05)
                        end
                    end
                end
            end
        end
    end

    -- TELEPORT TO BOSS
    local function teleportToBoss()
        if not teleportToBossEnabled then return end
        local bossNames = {"Dragon", "Don Swan", "Magma", "Awakened Ice Admiral", "Darkbeard", "Cake Queen", "Dough King"}
        for _, name in pairs(bossNames) do
            local boss = workspace:FindFirstChild(name)
            if boss and boss:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame = boss.HumanoidRootPart.CFrame * CFrame.new(0, 5, 8)
                break
            end
        end
    end

    -- AUTO QUEST
    local function autoQuest()
        if not autoQuestEnabled then return end
        pcall(function()
            local args = {[1] = "getquests", [2] = {}}
            local quests = ReplicatedStorage.Remotes.CommF_:InvokeServer(unpack(args))
            if quests then
                for _, quest in pairs(quests) do
                    if quest.LevelReq <= LocalPlayer.Data.Level.Value then
                        ReplicatedStorage.Remotes.CommF_:FireServer("startquest", quest.Id)
                        wait(1)
                        break
                    end
                end
            end
        end)
    end

    -- FAST ATTACK
    local function fastAttack()
        if not fastAttackEnabled then return end
        pcall(function()
            ReplicatedStorage.Remotes.CommF_:FireServer("KenHaki")
            ReplicatedStorage.Remotes.CommF_:FireServer("FlashStep")
        end)
    end

    -- NO CLIP
    local function noClip()
        if not noClipEnabled then return end
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CanCollide = false
        end
    end

    -- ESP
    local espLabels = {}
    local function updateESP()
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                if not espLabels[player] then
                    local label = Instance.new("TextLabel")
                    label.Size = UDim2.new(0, 120, 0, 22)
                    label.BackgroundColor3 = Color3.new(0, 0, 0)
                    label.BackgroundTransparency = 0.5
                    label.BorderSizePixel = 1
                    label.Parent = screenGui
                    label.Font = Enum.Font.GothamBold
                    label.TextSize = 13
                    espLabels[player] = label
                end
                local label = espLabels[player]
                if espEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local rootPos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
                    if onScreen then
                        label.TextColor3 = Color3.new(1, 0, 0)
                        label.Text = player.Name
                        label.Position = UDim2.new(0, rootPos.X - 60, 0, rootPos.Y - 40)
                        label.Visible = true
                    else
                        label.Visible = false
                    end
                else
                    if label then label.Visible = false end
                end
            end
        end
    end

    -- RESET COLLISION
    spawn(function()
        while true do
            if not noClipEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CanCollide = true
            end
            wait(1)
        end
    end)

    -- MAIN LOOP
    RunService.RenderStepped:Connect(function()
        updateESP()
        if autoFarmEnabled then autoFarm() end
        if oneHitKillEnabled then oneHitKill() end
        if autoCollectEnabled then autoCollect() end
        if teleportToBossEnabled then teleportToBoss() end
        if autoQuestEnabled then autoQuest() end
        if fastAttackEnabled then fastAttack() end
        if noClipEnabled then noClip() end
    end)

