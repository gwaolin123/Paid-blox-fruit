-- LICENSE CHECK
local function checkLicense()
    local key = keyBox.Text
    if validateKey(key) then
        loadPaidScript()
    else
        if validKeysList[key] and usedKeys[key] then
            errorText.Text = "Key already used on another device!"
        else
            errorText.Text = "Invalid License Key! Valid keys: bloxfruit_paid_v1 to v20"
        end
    end
end

submitBtn.MouseButton1Click:Connect(checkLicense)
keyBox.FocusLost:Connect(checkLicense)

